# per-machine vault path / overrides — never commit
memcon.config.local.yaml
__pycache__/
*.pyc
.DS_Store
.watcher.pid
.claude/
tmp/

# internal status / handoff doc — not for the public repo
MEMCON_STATUS.md

# Obsidian workspace state — personal, don't commit
vault/.obsidian/
vault/Untitled.*
vault/*.canvas
vault/*.base

# Private project docs — never ship these to the public repo.
# (strategy, monetization, internal architecture, personal planning)
vault/**/*PRIVATE*
vault/**/*STRATEGY*
vault/**/*ROADMAP*
vault/**/*_REFERENCE.md

# Entity index DB (v3.1) — regenerated locally, never commit
vault/.memcon/

# Migration backups
vault/_backup_v3.1*/

# Personal memory is PRIVATE — never commit real notes to the public repo. The
# repo ships only note templates + a couple of curated example notes. (Full fix:
# relocate the live vault out of the repo entirely — task #56.)
vault/**/*.md
!vault/_templates/**
!vault/debugging/claude_desktop_mcp_wired_up.md
